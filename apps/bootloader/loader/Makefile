#==============================================================================
# Bootloader Loader Makefile — Plan 001 Phase 1.5
#
# Builds the bootloader binary that lives in sector 0 (16 KB at 0x08000000).
# Uses linker/bootloader_ls.ld so the linker enforces the sector-0 size cap.
#
# Sources:
#   - main.c                  : header parse + jump-to-app
#   - $(BL_PUBKEY_C)          : generated by `make keys` from a fixed seed.
#                               Phase 1.5 only links it (verifies in 1.6).
#==============================================================================

MODULE_NAME := bootloader_loader

ifdef EXAMPLE
.DEFAULT_GOAL := $(EXAMPLE)
else
.DEFAULT_GOAL := help
endif

include ../../../Makefile.common

#==============================================================================
# Override the linker script — sector 0 only, no slot-region access.
#==============================================================================
LDSCRIPT := $(LINKER_DIR)/bootloader_ls.ld

LOCAL_BUILD_DIR := $(BUILD_DIR)/apps/bootloader/loader

#==============================================================================
# Sources
#==============================================================================
# Phase 1.8 splits the loader across three TUs:
#   - main.c     : reset-vector entry, magic-flag check, slot pick + verify-
#                  and-jump (Phase 1.5–1.7).
#   - verify.c   : header parse + SHA-256 + ECDSA — shared with ota.c so the
#                  same correctness path covers normal boot AND OTA.
#   - ota.c      : Phase 1.8 OTA receiver state machine — framing decoder,
#                  flash writer, atomic active-slot swap.
LOADER_SRCS := main.c verify.c ota.c $(BL_PUBKEY_C)
LOADER_OBJS := $(LOCAL_BUILD_DIR)/main.o \
               $(LOCAL_BUILD_DIR)/verify.o \
               $(LOCAL_BUILD_DIR)/ota.o \
               $(LOCAL_BUILD_DIR)/bootloader_pubkey.o

# Bootloader-specific includes:
#   lib/img     — header + slot metadata parser
#   lib/crypto  — SHA-256 + ECDSA verify (Phase 1.6)
#   lib/flash   — slot constants + Phase 1.8 mutation primitives
#   lib/framing — Phase 1.8 OTA wire protocol
LOADER_CFLAGS := -I$(LIB_DIR)/img/inc -I$(LIB_DIR)/crypto/inc \
                 -I$(LIB_DIR)/flash/inc -I$(LIB_DIR)/framing/inc

# CRYPTO_LIB ahead of IMG_LIB so the linker resolves crypto symbols first
# inside the start-group; FLASH_LIB and FRAMING_LIB land alongside since
# Phase 1.8 needs both the slot-erase + commit-metadata path and the
# framing decoder.  --gc-sections drops anything the OTA path doesn't
# call, so a non-OTA boot pays only for the cold-path flag check.
LOADER_DEPS := $(CRYPTO_LIB) $(FRAMING_LIB) $(FLASH_LIB) $(IMG_LIB) \
               $(DRIVERS_LIB) $(STARTUP_OBJ)

.PHONY: all clean help bootloader

help:
	@echo "Usage: make EXAMPLE=bootloader"

all: bootloader

bootloader: $(LOCAL_BUILD_DIR)/loader.bin
	@echo "Bootloader built successfully ($(LOCAL_BUILD_DIR)/loader.bin)."

# Compile main.c.
$(LOCAL_BUILD_DIR)/main.o: main.c verify.h ota.h
	$(make-build-dir)
	@echo "Compiling: $<"
	$(CC) $(CFLAGS) $(LOADER_CFLAGS) -o $@ $<

# Compile verify.c.
$(LOCAL_BUILD_DIR)/verify.o: verify.c verify.h
	$(make-build-dir)
	@echo "Compiling: $<"
	$(CC) $(CFLAGS) $(LOADER_CFLAGS) -o $@ $<

# Compile ota.c.
$(LOCAL_BUILD_DIR)/ota.o: ota.c ota.h verify.h
	$(make-build-dir)
	@echo "Compiling: $<"
	$(CC) $(CFLAGS) $(LOADER_CFLAGS) -o $@ $<

# Compile the generated pubkey C source.  `make keys` is invoked by the root
# Makefile before this rule runs, so $(BL_PUBKEY_C) is guaranteed to exist.
$(LOCAL_BUILD_DIR)/bootloader_pubkey.o: $(BL_PUBKEY_C)
	$(make-build-dir)
	@echo "Compiling: $<"
	$(CC) $(CFLAGS) -o $@ $<

# Link.
$(LOCAL_BUILD_DIR)/loader.elf: $(LOADER_OBJS) $(LOADER_DEPS)
	$(make-build-dir)
	@echo "Linking loader.elf..."
	$(CC) $(LDFLAGS) -Wl,-Map=$(LOCAL_BUILD_DIR)/loader.map,--cref \
		-o $@ $(LOADER_OBJS) -Wl,--start-group $(LOADER_DEPS) -Wl,--end-group -lc -lm -lgcc
	@echo "Linking complete."

# Sector-0 budget guard.  The linker ASSERT in bootloader_ls.ld covers
# _etext only — it does not see the .data LMA copy that ends up in flash.
# This bin-level check is the authoritative final guard against the
# bootloader exceeding 16 KB.  Works on both BSD stat (macOS) and GNU stat.
SECTOR0_LIMIT := 16384

$(LOCAL_BUILD_DIR)/loader.bin: $(LOCAL_BUILD_DIR)/loader.elf
	$(CP) -O binary $< $@
	@echo "Created loader.bin"
	@$(SZ) $<
	@sz=$$(stat -f%z $@ 2>/dev/null || stat -c%s $@); \
	if [ $$sz -gt $(SECTOR0_LIMIT) ]; then \
		echo "ERROR: loader.bin $$sz bytes > $(SECTOR0_LIMIT) (sector 0 budget)"; \
		exit 1; \
	else \
		echo "loader.bin size OK: $$sz / $(SECTOR0_LIMIT) bytes"; \
	fi

clean:
	@echo "Cleaning bootloader loader..."
	@rm -rf $(LOCAL_BUILD_DIR)
